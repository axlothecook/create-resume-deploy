# Template for the env vars the Compose stack injects. Copy this to `.env` on the Pi
# and fill in the real values. `.env` is gitignored — never commit real secrets.

# --- Backend (injected into the `backend` service via env_file) -------------

# Run in production mode → secure (HTTPS-only) session cookies + trust the proxy
# (the app sits behind the Cloudflare Tunnel).
NODE_ENV=production

# Port the Express backend listens on INSIDE its container. The cloudflared route
# for the API must point at backend:3006 to match this.
PORT=3006

# MongoDB connection string. Inside the Compose network the database is reached by
# the SERVICE NAME `mongo`, not `localhost`. DB name keeps the underscore form.
MONGO_URI=mongodb://mongo:27017/create_resume

# The exact public origin of the FRONTEND — the backend's CORS allow-list. Must be
# the https:// production domain so the session cookie is accepted cross-origin.
CLIENT_ORIGIN=https://resume.axlothecook.com

# Secret used to sign the session cookie. Generate a long random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# --- Cloudflare Tunnel (injected into the `cloudflared` service) ------------
# Zero Trust dashboard -> Networks -> Tunnels -> your tunnel -> the long string
# after `--token` in the install command. Only needed on the production stack.
TUNNEL_TOKEN=
